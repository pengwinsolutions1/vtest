ai-local/Hunyuan3D-2/
ai-local/TripoSR/
ai-local/brush/
ai-local/target/

# Legacy iterations — kept locally for reference, not version-controlled
archive/

# User's scratch / test imagery for the parked photogrammetry experiments
garmets/

# Loose test PNGs in the project root (user's scratch images). Add specific
# ones explicitly with `git add -f` if needed.
/*.png
/*.jpg
/*.jpeg
/*.mp4
/*.glb

