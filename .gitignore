# ============================================================================
node_modules/
.next/
out/
dist/
build/
.npm/
.eslintcache
*.tsbuildinfo
next-env.d.ts

# Webapp runtime data — SQLite + customer uploads. Regenerated from seed.
webapp/data/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

