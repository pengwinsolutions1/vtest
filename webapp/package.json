{
  "name": "virtualtryon-webapp",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "electron:dev": "concurrently -k -n next,electron -c blue,green \"next dev -p 3000\" \"wait-on http://localhost:3000 && ELECTRON_DEV=1 node scripts/run-electron.js\"",
    "electron:start": "node scripts/run-electron.js"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "better-sqlite3": "^11.5.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "replicate": "^1.0.1",
    "three": "^0.184.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "electron": "^33.4.11",
    "typescript": "^5.6.3",
    "wait-on": "^9.0.10"
  }
}
